# ── LLM Provider ─────────────────────────────────────────
# Primary chat provider (recommended: groq)
# Get your key at https://console.groq.com/keys
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here

# Optional fallbacks (for provider switching)
# Get OpenAI key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Get Anthropic key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Get OpenRouter key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Vision Provider ───────────────────────────────────────
# Set to "gemini" and add GEMINI_API_KEY to enable real image analysis
# Default is "mock" — works offline with no API key needed
# Get Gemini key at https://aistudio.google.com/apikey
VISION_PROVIDER=mock
GEMINI_API_KEY=your_gemini_api_key_here

# ── Flask Config ──────────────────────────────────────────
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=1
